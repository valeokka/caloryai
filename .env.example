# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calorie_bot
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Telegram Payments
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token_here

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
PORT=3000

# Advanced Configuration (optional, defaults are set in constants.js)
# Uncomment and modify if you need to override defaults

# OpenAI Settings
# OPENAI_TIMEOUT=30000
# OPENAI_MAX_RETRIES=2
# OPENAI_MAX_TOKENS=500

# Database Pool Settings
# DB_MAX_CONNECTIONS=20
# DB_MIN_CONNECTIONS=2
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=2000
# DB_STATEMENT_TIMEOUT=10000

# Validation Limits
# WEIGHT_MIN=10
# WEIGHT_MAX=5000
# WEIGHT_ABSOLUTE_MAX=10000
# MAX_CALORIES=10000
# MAX_PROTEIN=1000
# MAX_FAT=1000
# MAX_CARBS=1000
# MAX_PHOTO_SIZE_MB=5

# Cache Settings
# CACHE_ENABLED=true
# CACHE_TTL_HOURS=24
# DB_CACHE_ENABLED=true
# DB_CACHE_TTL_MS=60000

# Image Compression Settings
# IMAGE_COMPRESSION_ENABLED=true
# IMAGE_MAX_WIDTH=1920
# IMAGE_MAX_HEIGHT=1920
# IMAGE_QUALITY=85
# IMAGE_FORMAT=jpeg
