# OpenAI Configuration (gpt-4o-mini + low quality)
OPENAI_API_KEY=your_api_key_here

# Image Processing (ОТКЛЮЧЕНО - base64 занимает слишком много токенов!)
IMAGE_COMPRESSION_ENABLED=false
IMAGE_QUALITY=85
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1920
IMAGE_FORMAT=jpeg

# Caching (избегает повторных запросов)
CACHE_ENABLED=true
CACHE_TTL_HOURS=24
DB_CACHE_ENABLED=true
DB_CACHE_TTL_MS=60000

# Validation
WEIGHT_MIN=10
WEIGHT_MAX=5000
WEIGHT_ABSOLUTE_MAX=10000
MAX_CALORIES=10000
MAX_PROTEIN=1000
MAX_FAT=1000
MAX_CARBS=1000
MAX_PHOTO_SIZE_MB=5

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000
DB_STATEMENT_TIMEOUT=10000
DB_ACQUIRE_TIMEOUT=60000
DB_EVICTION_INTERVAL=10000

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Environment
NODE_ENV=production
PORT=3000
